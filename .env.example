# --- Required for production batch ---
# PostgreSQL connection string (Lambda must reach the DB: VPC / RDS proxy / public as appropriate)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# TLS to Postgres: set to false for local dev if you see "self-signed certificate in certificate chain"
# (corporate / RDS-style certs). Prefer a real CA bundle in production instead of turning this off.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Force TLS on/off. Leave unset: localhost = no TLS, any other host = TLS (fixes Lambda→RDS "no encryption").
# DATABASE_USE_SSL=false

# AWS region for SES client and general SDK usage
AWS_REGION=ap-south-1

# Actor recorded on leave_adjustments.createdById (system / batch user id in your app)
SYSTEM_USER_ID=

# Verified SES identity (or domain) — From address
SES_FROM_EMAIL=hr-notifications@example.com
# Display name shown in mail clients
SES_FROM_NAME=HR Batch

# Single distribution list / shared inbox for celebration digests (not per-employee)
SES_NOTIFICATION_TO=people-team@example.com

# --- Scheduling & timezone (business logic) ---
# IANA zone used for “today”, first-of-month, and celebration calendar matching
APP_TIMEZONE=Asia/Kolkata

# Intended local run time (documentation + local testing). EventBridge cron is UTC — see README.
BATCH_HOUR=8
BATCH_MINUTE=1

# Deploy-time: EventBridge schedule expression in UTC.
# Default in serverless.yml: cron(31 2 * * ? *)  == 08:01 Asia/Kolkata (IST = UTC+5:30).
SCHEDULE_CRON=cron(31 2 * * ? *)

# --- Leave accrual ---
LEAVE_ACCRUAL_AMOUNT=1.5

# Leave year resolution (choose ONE mode)
# env = use CURRENT_LEAVE_YEAR_ID only
# table = resolve by date range in LEAVE_YEAR_TABLE
LEAVE_YEAR_LOOKUP_MODE=env
# When LEAVE_YEAR_LOOKUP_MODE=env
CURRENT_LEAVE_YEAR_ID=1
# When LEAVE_YEAR_LOOKUP_MODE=table (identifiers: letters, numbers, underscore only)
LEAVE_YEAR_TABLE=
LEAVE_YEAR_ID_COLUMN=
LEAVE_YEAR_START_COLUMN=
LEAVE_YEAR_END_COLUMN=

# --- Employee activity filter (centralized in code) ---
# If set (comma-separated), ONLY these statuses are active
ACTIVE_EMPLOYEE_STATUSES=employee_status
# If ACTIVE_EMPLOYEE_STATUSES is empty, exclude these (default includes INACTIVE when unset in app)
INACTIVE_EMPLOYEE_STATUSES=INACTIVE

# --- Email template images ---
# Upload the contents of the `public/` folder to an S3 bucket (or any public CDN).
# Then set this to the base URL where those files are served — no trailing slash.
# Example (S3 public bucket):
#   CELEBRATION_ASSET_BASE_URL=https://your-bucket.s3.ap-south-1.amazonaws.com/celebrations
# Example (CloudFront distribution):
#   CELEBRATION_ASSET_BASE_URL=https://dXXXXXXXXXXXX.cloudfront.net/celebrations
# If left unset, inline SVG fallbacks are used in the email (still looks fine, just no photos).
CELEBRATION_ASSET_BASE_URL=

# --- Optional SES ---
SES_REPLY_TO=
SES_CONFIGURATION_SET=

# --- Ops ---
LOG_LEVEL=info
NODE_ENV=development
